# --- BASIC USAGE ---

# summarize a web page
summarize "https://example.com"

# summarize a YouTube video
summarize "https://youtu.be/VIDEO_ID" --youtube auto

# summarize a local file
summarize ./document.pdf

# summarize clipboard content
pbpaste | summarize -

# --- YOUTUBE OPTIONS ---

# auto transcript (tries web → apify → yt-dlp)
summarize "https://youtu.be/VIDEO_ID" --youtube auto

# web captions only (fastest, no fallback)
summarize "https://youtu.be/VIDEO_ID" --youtube web

# skip auto-generated captions (human captions only)
summarize "https://youtu.be/VIDEO_ID" --youtube no-auto

# force yt-dlp download + transcription
summarize "https://youtu.be/VIDEO_ID" --youtube yt-dlp

# use apify for transcript (needs APIFY_API_TOKEN)
summarize "https://youtu.be/VIDEO_ID" --youtube apify

# include timestamps in transcript
summarize "https://youtu.be/VIDEO_ID" --youtube auto --timestamps

# --- VIDEO MODE ---

# auto (default): prefers video understanding if model supports it, else transcript
summarize "https://youtu.be/VIDEO_ID" --video-mode auto

# understand: send video frames directly to the LLM (skips transcript)
# best for: visual content (demos, whiteboard, diagrams, code on screen)
# best for: videos with poor/no captions
# note: uses more tokens, needs a model with video support (e.g. Gemini)
summarize "https://youtu.be/VIDEO_ID" --video-mode understand

# transcript: force transcript-based summary (ignore video frames)
# best for: podcasts, interviews, talking-head videos
# best for: long videos (cheaper, faster)
summarize "https://youtu.be/VIDEO_ID" --video-mode transcript

# --- SLIDES (YouTube / video) ---

# extract slides inline with summary
summarize "https://youtu.be/VIDEO_ID" --slides

# slides with OCR (requires tesseract)
summarize "https://youtu.be/VIDEO_ID" --slides --slides-ocr

# full transcript with interleaved slides
summarize "https://youtu.be/VIDEO_ID" --slides --extract

# --- SUMMARY LENGTH ---

# short / medium / long / xl (default) / xxl
summarize "https://youtu.be/VIDEO_ID" --length short
summarize "https://youtu.be/VIDEO_ID" --length xxl

# exact character limit
summarize "https://youtu.be/VIDEO_ID" --length 20k

# --- MODEL SELECTION ---

# auto model selection (default, uses available keys)
summarize "https://example.com" --model auto

# specific provider/model
summarize "https://example.com" --model openai/gpt-5-mini
summarize "https://example.com" --model anthropic/claude-sonnet-4-5
summarize "https://example.com" --model openrouter/google/gemini-3-flash-preview

# use a local CLI provider (claude, gemini, codex)
summarize "https://example.com" --cli claude

# --- CUSTOM PROMPTS ---

# override the summary prompt
summarize "https://youtu.be/VIDEO_ID" --prompt "Focus on actionable takeaways"

# read prompt from a file
summarize "https://youtu.be/VIDEO_ID" --prompt-file ./my-prompt.txt

# --- EXTRACT ONLY (no LLM summary) ---

# extract raw text
summarize "https://example.com" --extract

# extract as markdown
summarize "https://example.com" --extract --format md

# extract YouTube transcript as formatted markdown via LLM
summarize "https://youtu.be/VIDEO_ID" --extract --format md --markdown-mode llm

# --- OUTPUT OPTIONS ---

# output language
summarize "https://youtu.be/VIDEO_ID" --lang en
summarize "https://youtu.be/VIDEO_ID" --lang de

# JSON output with metrics
summarize "https://example.com" --json

# plain text (no ANSI rendering)
summarize "https://example.com" --plain

# change theme (aurora, ember, moss, mono)
summarize "https://example.com" --theme moss

# --- WEBSITE OPTIONS ---

# use firecrawl for extraction (needs FIRECRAWL_API_KEY)
summarize "https://example.com" --firecrawl always

# --- CACHE ---

# bypass LLM cache
summarize "https://example.com" --no-cache

# bypass media download cache
summarize "https://youtu.be/VIDEO_ID" --no-media-cache

# show cache stats
summarize --cache-stats

# clear cache
summarize --clear-cache

# --- TRANSCRIPTION ---

# choose transcription backend (for audio/video without captions)
summarize "https://youtu.be/VIDEO_ID" --transcriber whisper
summarize "https://youtu.be/VIDEO_ID" --transcriber parakeet

# set up local ONNX transcription
summarize transcriber setup

# --- DEBUGGING ---

# verbose progress info
summarize "https://example.com" --verbose

# detailed metrics
summarize "https://example.com" --metrics detailed

# --- RECOMMENDED COMBOS ---

# thorough youtube summary with timestamps
summarize "https://youtu.be/VIDEO_ID" --youtube auto --length xxl --timestamps

# presentation/talk with slide extraction
summarize "https://youtu.be/VIDEO_ID" --youtube auto --slides --slides-ocr --length xxl

# quick youtube summary
summarize "https://youtu.be/VIDEO_ID" --youtube auto --length short

# tailored summary with custom prompt
summarize "https://youtu.be/VIDEO_ID" --prompt "List key arguments and counterarguments" --length xxl

# --- CONFIG ---

# config file location
# ~/.summarize/config.json

# store API keys in config
# { "env": { "OPENROUTER_API_KEY": "..." } }

# set default model in config
# { "model": "openrouter/google/gemini-3-flash-preview" }
