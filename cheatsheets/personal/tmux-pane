# --- Creating & Closing ---

# split vertically (side by side) in CWD
Ctrl-a |

# split horizontally (top/bottom) in CWD
Ctrl-a -

# kill current pane with confirmation
Ctrl-a x

# close pane instantly (sends EOF)
Ctrl-d

# --- Navigating ---

# move to left / down / up / right pane
Ctrl-h / j / k / l

# cycle through panes (forward by index)
Ctrl-a o

# flash pane numbers then press number to jump
Ctrl-a q

# go to last active pane
Ctrl-a ;

# --- Resizing ---

# resize pane in 5-cell increments (vim keys, no prefix)
Alt-h / j / k / l

# resize pane in 5-cell increments (arrow keys)
Ctrl-a Alt-up/down/left/right

# resize pane in 1-cell increments
Ctrl-a Ctrl-up/down/left/right

# toggle zoom current pane fullscreen
Ctrl-a z

# --- Swapping & Reordering ---

# swap pane with previous / next (by index)
Ctrl-a { / }

# swap pane 1 with pane 2
Ctrl-a : swap-pane -s 1 -t 2

# rotate panes forward in current window
Ctrl-a : rotate-window

# --- Layouts ---

# cycle through preset layouts
Ctrl-a Space

# all panes side by side (even-horizontal)
Ctrl-a Alt-1

# all panes stacked (even-vertical)
Ctrl-a Alt-2

# main pane top, others side by side below (main-horizontal)
Ctrl-a Alt-3

# main pane left, others stacked right (main-vertical)
Ctrl-a Alt-4

# tiled (equal grid)
Ctrl-a Alt-5

# --- Moving Panes Between Windows ---

# send current pane to another window (stacked)
Ctrl-a @

# send current pane to another window (side by side)
Ctrl-a #

# break pane into its own new window
Ctrl-a !

# move (push) pane into window 2 side by side
Ctrl-a : join-pane -h -t :2

# move (push) pane into window 2 stacked
Ctrl-a : join-pane -v -t :2

# pull pane from window 2 into current side by side
Ctrl-a : join-pane -h -s :2

# pull pane from window 2 into current stacked
Ctrl-a : join-pane -v -s :2

# --- Marking & Targeting ---

# mark/unmark current pane (for use with -t '{marked}')
Ctrl-a m

# pull marked pane into current window (stacked)
Ctrl-a V

# pull marked pane into current window (side by side)
Ctrl-a H

# --- Misc ---

# show pane numbers and sizes
Ctrl-a q

# display pane info (index, tty, size)
Ctrl-a : display-message -p '#{pane_index} #{pane_tty} #{pane_width}x#{pane_height}'

# pipe pane output to a log file
Ctrl-a : pipe-pane -o 'cat >> ~/pane.log'

# stop piping
Ctrl-a : pipe-pane
